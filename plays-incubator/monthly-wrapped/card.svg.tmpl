<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0d1b2a"/>
      <stop offset="1" stop-color="#1b263b"/>
    </linearGradient>
    <linearGradient id="hero" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#ff8800"/>
      <stop offset="1" stop-color="#ffd60a"/>
    </linearGradient>
  </defs>
  <rect width="1080" height="1080" fill="url(#bg)"/>

  <!-- 顶部标头 -->
  <text x="60" y="88" font-family="Noto Sans CJK SC,sans-serif" font-size="30" fill="#aab4c4">电车有数 · 月度行车报告</text>
  <text x="1020" y="88" text-anchor="end" font-family="Noto Sans CJK SC,sans-serif" font-size="26" fill="#5a6a80">${window_label}</text>

  <!-- 中央英雄数字：本月总里程（注意：占位符必须用 compute var / SQL 列名，output 字段名运行时不注入） -->
  <text x="540" y="330" text-anchor="middle" font-family="Noto Sans CJK SC,sans-serif" font-weight="bold" font-size="170" fill="url(#hero)">${total_km_r}<tspan font-size="56" fill="#aab4c4"> km</tspan></text>
  <text x="540" y="425" text-anchor="middle" font-family="Noto Sans CJK SC,sans-serif" font-size="52" fill="#ffffff">${persona.title}</text>
  <text x="540" y="480" text-anchor="middle" font-family="Noto Sans CJK SC,sans-serif" font-size="28" fill="#aab4c4">${persona.desc}</text>

  <!-- 六宫格统计 -->
  <g font-family="Noto Sans CJK SC,sans-serif">
    <rect x="60" y="525" width="470" height="100" rx="16" fill="#16263c" stroke="#2a3a52"/>
    <text x="84" y="563" font-size="22" fill="#7a8aa0">出行次数</text>
    <text x="84" y="607" font-size="40" fill="#ff8800">${drive_count} 次</text>

    <rect x="550" y="525" width="470" height="100" rx="16" fill="#16263c" stroke="#2a3a52"/>
    <text x="574" y="563" font-size="22" fill="#7a8aa0">在路上</text>
    <text x="574" y="607" font-size="40" fill="#2ec4b6">${hours_1dp} 小时</text>

    <rect x="60" y="645" width="470" height="100" rx="16" fill="#16263c" stroke="#2a3a52"/>
    <text x="84" y="683" font-size="22" fill="#7a8aa0">最长一程</text>
    <text x="84" y="727" font-size="40" fill="#ffd60a">${longest_r} km</text>

    <rect x="550" y="645" width="470" height="100" rx="16" fill="#16263c" stroke="#2a3a52"/>
    <text x="574" y="683" font-size="22" fill="#7a8aa0">最高时速</text>
    <text x="574" y="727" font-size="40" fill="#ef476f">${top_speed_r} km/h</text>

    <rect x="60" y="765" width="470" height="100" rx="16" fill="#16263c" stroke="#2a3a52"/>
    <text x="84" y="803" font-size="22" fill="#7a8aa0">充电</text>
    <text x="84" y="847" font-size="40" fill="#2ec4b6">${charge_count} 次 · ${kwh_r} kWh</text>

    <rect x="550" y="765" width="470" height="100" rx="16" fill="#16263c" stroke="#2a3a52"/>
    <text x="574" y="803" font-size="22" fill="#7a8aa0">活跃天数</text>
    <text x="574" y="847" font-size="40" fill="#ffd60a">${active_days} 天</text>
  </g>

  <!-- 高光时刻 -->
  <text x="540" y="925" text-anchor="middle" font-family="Noto Sans CJK SC,sans-serif" font-size="30" fill="#ffd60a">${busiest_day} 是你最野的一天 · 单日 ${busiest_km_r} km</text>

  <!-- 夜行习性胶囊（Batik 是 SVG 1.1，不认 #RRGGBBAA 8 位 hex，必须用 fill-opacity） -->
  <rect x="330" y="945" width="420" height="56" rx="28" fill="#2ec4b6" fill-opacity="0.13" stroke="#2ec4b6"/>
  <text x="540" y="983" text-anchor="middle" font-family="Noto Sans CJK SC,sans-serif" font-size="30" fill="#2ec4b6">夜行画像 · ${night_tag}</text>

  <!-- 底部信息条 -->
  <text x="60" y="1050" font-family="Noto Sans CJK SC,sans-serif" font-size="24" fill="#5a6a80">${car_model} · ${window_label}</text>
  <text x="1020" y="1050" text-anchor="end" font-family="Noto Sans CJK SC,sans-serif" font-size="22" fill="#5a6a80">${watermark}</text>
</svg>
