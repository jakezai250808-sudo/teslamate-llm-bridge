<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1080 1080" width="1080" height="1080">
  <!-- night-owl share card · rendered at 1080x1080 PNG · CJK via Noto Sans CJK -->
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0b1026"/>
      <stop offset="1" stop-color="#1d2452"/>
    </linearGradient>
  </defs>

  <rect x="0" y="0" width="1080" height="1080" fill="url(#sky)"/>

  <!-- stars -->
  <circle cx="140" cy="120" r="3" fill="#ffffff" opacity="0.8"/>
  <circle cx="320" cy="80"  r="2" fill="#ffffff" opacity="0.6"/>
  <circle cx="860" cy="150" r="3" fill="#ffffff" opacity="0.7"/>
  <circle cx="960" cy="90"  r="2" fill="#ffffff" opacity="0.5"/>
  <circle cx="620" cy="60"  r="2" fill="#ffffff" opacity="0.6"/>
  <!-- moon -->
  <circle cx="900" cy="220" r="70" fill="#f5e9c8"/>
  <circle cx="870" cy="200" r="62" fill="#141a3a"/>

  <text x="90" y="180" font-family="Noto Sans CJK SC, sans-serif" font-size="44" fill="#9aa3c7">${car_name} · ${car_model}</text>
  <!-- NOTE: no emoji in SVG text — the render host only ships Noto Sans CJK (no emoji
       font) and Batik cannot render color emoji; non-BMP code points are rejected by
       the engine's template lint. Emoji belongs in the manifest `emoji:` field. -->
  <text x="90" y="300" font-family="Noto Sans CJK SC, sans-serif" font-size="88" font-weight="700" fill="#ffffff">夜猫子指数</text>
  <text x="90" y="370" font-family="Noto Sans CJK SC, sans-serif" font-size="40" fill="#9aa3c7">${window_label}</text>

  <!-- big score -->
  <text x="90" y="600" font-family="Noto Sans CJK SC, sans-serif" font-size="220" font-weight="800" fill="${persona.color}">${owl_score}</text>
  <text x="560" y="600" font-family="Noto Sans CJK SC, sans-serif" font-size="64" fill="#9aa3c7">/ 100</text>

  <!-- score bar: bar_width is a number var (validated numeric before injection) -->
  <rect x="90" y="650" width="800" height="26" rx="13" fill="#2a3263"/>
  <rect x="90" y="650" width="${bar_width}" height="26" rx="13" fill="${persona.color}"/>

  <!-- persona -->
  <text x="90" y="790" font-family="Noto Sans CJK SC, sans-serif" font-size="72" font-weight="700" fill="#ffffff">${persona.name}</text>
  <text x="90" y="850" font-family="Noto Sans CJK SC, sans-serif" font-size="36" fill="${persona.color}">${persona.tagline}</text>

  <!-- stats line -->
  <text x="90" y="940" font-family="Noto Sans CJK SC, sans-serif" font-size="38" fill="#c7cdee">深夜行程 ${night_drives}/${total_drives} 段 · ${night_km} km · 占比 ${night_ratio}%</text>

  <text x="90" y="1020" font-family="Noto Sans CJK SC, sans-serif" font-size="28" fill="#5a628f">teslamate-llm-bridge · ${generated_at}</text>
</svg>
