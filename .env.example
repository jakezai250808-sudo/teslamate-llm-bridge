# teslamate-llm-bridge environment configuration
# Copy this file to .env and fill in your values.
# All variables have sensible defaults; the only one you MUST set is TM_DB_PASS.

# -- TeslaMate PostgreSQL connection --
TM_DB_HOST=localhost
TM_DB_PORT=5432
TM_DB_NAME=teslamate
TM_DB_USER=teslamate
TM_DB_PASS=

# -- Optional: car whitelist --
# Comma-separated TeslaMate car IDs (from: SELECT id FROM cars;)
# When blank, all car IDs are allowed (single-tenant / personal use).
CAR_IDS=

# -- Optional: API authentication --
# Require this Bearer token on all /api/** endpoints.
# When blank, authentication is DISABLED (safe for localhost-only use).
# For internet-facing: openssl rand -hex 32
API_TOKEN=

# -- Optional: custom plays directory --
# Path inside the container to an additional plays directory.
# Mount your local play folder as a volume in docker-compose.yml.
PLAYS_DIR=
