<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080">
  <!-- teslamate-llm-bridge Play Engine 卡片骨架：1080×1080 小红书 1:1，深色 slate 系配色。
       占位符（dollar-brace 语法）由引擎注入并 XML 转义；可用：compute var / output 字段 / 内置
       ${car_name} ${car_model} ${window_label} ${generated_at} ${window_days}，
       lookup object 用点路径 ${persona.name}。
       禁止：script 标签、foreignObject、xlink href、外链 href、DTD（加载期 lint 拒载）。
       字体：prod base image 已装 fonts-noto-cjk，font-family 写 Noto Sans CJK SC。 -->
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0F172A"/>
      <stop offset="1" stop-color="#1E293B"/>
    </linearGradient>
  </defs>
  <rect width="1080" height="1080" fill="url(#bg)"/>

  <!-- 品牌区 -->
  <text x="540" y="90" text-anchor="middle" fill="#F1F5F9" font-size="56" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">电车有数</text>
  <text x="540" y="140" text-anchor="middle" fill="#94A3B8" font-size="28"
        font-family="Noto Sans CJK SC,sans-serif">夜猫子指数</text>
  <line x1="120" y1="180" x2="960" y2="180" stroke="#334155" stroke-width="2"/>

  <!-- 巨大分数 -->
  <text x="540" y="430" text-anchor="middle" fill="#34D399" font-size="220" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${score}</text>
  <text x="540" y="510" text-anchor="middle" fill="#FBBF24" font-size="44" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${persona.name}</text>

  <!-- 一句话点评 -->
  <text x="540" y="600" text-anchor="middle" fill="#CBD5E1" font-size="30"
        font-family="Noto Sans CJK SC,sans-serif">${persona.comment}</text>
  <text x="540" y="660" text-anchor="middle" fill="#94A3B8" font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">${summary}</text>

  <!-- 底部信息条 -->
  <line x1="120" y1="972" x2="960" y2="972" stroke="#334155" stroke-width="1.5"/>
  <text x="140" y="1020" fill="#94A3B8" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${car_name} · ${window_label} · ${generated_at}</text>
  <!-- Replace the text below with your own domain, or remove this element entirely -->
  <text x="940" y="1020" text-anchor="end" fill="#64748B" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">your-domain.example.com</text>
</svg>
