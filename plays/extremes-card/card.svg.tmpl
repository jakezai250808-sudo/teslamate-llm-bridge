<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080">
  <!-- 本月之最分享卡：1080x1080，深海蓝黑背景 + 双数字锤 + 五条色彩极值条形图 + 档位徽章。
       占位符由引擎注入并 XML 转义；bar_* 为 compute 数值（轨道 480px）。
       不放 emoji 字面，所有图形用几何形状 + Noto Sans CJK SC 文字替代。 -->
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0d1b2a"/>
      <stop offset="0.5" stop-color="#0f1e2e"/>
      <stop offset="1" stop-color="#112233"/>
    </linearGradient>
    <linearGradient id="divgrad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#f5a623"/>
      <stop offset="1" stop-color="#39d353"/>
    </linearGradient>
    <!-- 条形图轨道渐变（每项独立色已在 rect fill 硬编码） -->
  </defs>

  <!-- 背景 -->
  <rect width="1080" height="1080" fill="url(#bg)"/>

  <!-- ======================================================
       顶栏 (y 0-120)
       ====================================================== -->
  <!-- 闪电菱形 icon -->
  <polygon points="60,34 76,62 60,90 44,62" fill="#f5a623" fill-opacity="0.9"/>
  <polygon points="60,44 68,62 60,80 52,62" fill="#0d1b2a" fill-opacity="0.7"/>

  <text x="96" y="72" fill="#f1f5f9" font-size="44" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">电车有数 · 本月之最</text>
  <text x="96" y="108" fill="#8899aa" font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">${window_label} · ${car_name}</text>

  <line x1="60" y1="124" x2="1020" y2="124" stroke="#1e3347" stroke-width="2"/>

  <!-- ======================================================
       数字锤区 (y 130-390)
       两个最醒目数字：最远一程(橙黄) + 最快瞬间(电光白)
       ====================================================== -->
  <!-- 左块：最远一程 -->
  <rect x="60" y="138" width="468" height="230" rx="12" fill="#112233" fill-opacity="0.8"/>
  <text x="284" y="192" text-anchor="middle" fill="#8899aa" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">最远一程</text>
  <text x="284" y="312" text-anchor="middle" fill="#f5a623" font-size="100" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${longest_km_r}</text>
  <text x="284" y="352" text-anchor="middle" fill="#8899aa" font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">km</text>

  <!-- 右块：最快瞬间 -->
  <rect x="552" y="138" width="468" height="230" rx="12" fill="#112233" fill-opacity="0.8"/>
  <text x="786" y="192" text-anchor="middle" fill="#8899aa" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">最快瞬间</text>
  <text x="786" y="312" text-anchor="middle" fill="#e8f4ff" font-size="100" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${top_speed_r}</text>
  <text x="786" y="352" text-anchor="middle" fill="#8899aa" font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">km/h</text>

  <!-- 渐变分隔线 -->
  <rect x="60" y="386" width="960" height="4" rx="2" fill="url(#divgrad)"/>

  <!-- ======================================================
       条形图区 (y 400-820)
       五条极值：最远/最快/最大功率/最高海拔/最久充电
       轨道 x=240 宽 480px；标签 x=60；数值 x=740；高度 28px 间距 72px
       ====================================================== -->

  <!-- 行 1：最远一程 (y=432 轨道 y=418) -->
  <text x="60" y="438" fill="#8899aa" font-size="23"
        font-family="Noto Sans CJK SC,sans-serif">最远一程</text>
  <!-- 菱形 bullet -->
  <polygon points="218,428 226,436 218,444 210,436" fill="#f5a623"/>
  <!-- 轨道底色 -->
  <rect x="234" y="420" width="480" height="28" rx="6" fill="#1a2d3f"/>
  <!-- 进度条 -->
  <rect x="234" y="420" width="${bar_dist}" height="28" rx="6" fill="#f5a623"/>
  <text x="740" y="442" fill="#e2e8f0" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${longest_km_r} km</text>

  <!-- 行 2：最快瞬间 (y=504) -->
  <text x="60" y="510" fill="#8899aa" font-size="23"
        font-family="Noto Sans CJK SC,sans-serif">最快瞬间</text>
  <polygon points="218,500 226,508 218,516 210,508" fill="#e8f4ff"/>
  <rect x="234" y="492" width="480" height="28" rx="6" fill="#1a2d3f"/>
  <rect x="234" y="492" width="${bar_speed}" height="28" rx="6" fill="#e8f4ff"/>
  <text x="740" y="514" fill="#e2e8f0" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${top_speed_r} km/h</text>

  <!-- 行 3：最大功率 (y=576) -->
  <text x="60" y="582" fill="#8899aa" font-size="23"
        font-family="Noto Sans CJK SC,sans-serif">最大功率</text>
  <polygon points="218,572 226,580 218,588 210,580" fill="#39d353"/>
  <rect x="234" y="564" width="480" height="28" rx="6" fill="#1a2d3f"/>
  <rect x="234" y="564" width="${bar_power}" height="28" rx="6" fill="#39d353"/>
  <text x="740" y="586" fill="#e2e8f0" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${peak_power_r} kW</text>

  <!-- 行 4：最高海拔 (y=648) -->
  <text x="60" y="654" fill="#8899aa" font-size="23"
        font-family="Noto Sans CJK SC,sans-serif">最高海拔</text>
  <polygon points="218,644 226,652 218,660 210,652" fill="#64b5f6"/>
  <rect x="234" y="636" width="480" height="28" rx="6" fill="#1a2d3f"/>
  <rect x="234" y="636" width="${bar_elev}" height="28" rx="6" fill="#64b5f6"/>
  <text x="740" y="658" fill="#e2e8f0" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${max_elev_r} m</text>

  <!-- 行 5：最久充电 (y=720) -->
  <text x="60" y="726" fill="#8899aa" font-size="23"
        font-family="Noto Sans CJK SC,sans-serif">最久充电</text>
  <polygon points="218,716 226,724 218,732 210,724" fill="#ffb347"/>
  <rect x="234" y="708" width="480" height="28" rx="6" fill="#1a2d3f"/>
  <rect x="234" y="708" width="${bar_charge}" height="28" rx="6" fill="#ffb347"/>
  <text x="740" y="730" fill="#e2e8f0" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${longest_charge_h} h</text>

  <line x1="60" y1="754" x2="1020" y2="754" stroke="#1e3347" stroke-width="1.5"/>

  <!-- ======================================================
       档位徽章区 (y 762-888)
       速度档位 + 充电档位，各做胶囊徽章
       ====================================================== -->

  <!-- 速度档位徽章（左） -->
  <rect x="60" y="770" width="450" height="100" rx="18" fill="#1c2e40" fill-opacity="0.9"
        stroke="#e8f4ff" stroke-width="1" stroke-opacity="0.3"/>
  <text x="285" y="811" text-anchor="middle" fill="#e8f4ff" font-size="24" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${speed_label.text}</text>
  <text x="285" y="848" text-anchor="middle" fill="#93c5fd" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">${speed_label.tag}</text>

  <!-- 充电档位徽章（右） -->
  <rect x="530" y="770" width="490" height="100" rx="18" fill="#1c2e30" fill-opacity="0.9"
        stroke="#ffb347" stroke-width="1" stroke-opacity="0.3"/>
  <text x="775" y="811" text-anchor="middle" fill="#ffb347" font-size="24" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${charge_label.text}</text>
  <text x="775" y="848" text-anchor="middle" fill="#fcd38d" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">${charge_label.tag}</text>

  <!-- 海拔档位（小徽章居中） -->
  <rect x="300" y="880" width="480" height="52" rx="10" fill="#17283a" fill-opacity="0.9"
        stroke="#64b5f6" stroke-width="1" stroke-opacity="0.4"/>
  <text x="540" y="914" text-anchor="middle" fill="#64b5f6" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${elev_label.text} ${elev_label.tag}</text>

  <!-- ======================================================
       底栏 (y 944-1080)
       ====================================================== -->
  <line x1="60" y1="944" x2="1020" y2="944" stroke="#1e3347" stroke-width="1.5"/>

  <!-- 统计小字 -->
  <text x="60" y="978" fill="#556677" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">本月 ${drive_count} 次出行 · ${charge_count} 次充电</text>
  <text x="1020" y="978" text-anchor="end" fill="#556677" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">${generated_at}</text>

  <!-- 摘要一行 -->
  <text x="540" y="1018" text-anchor="middle" fill="#8899aa" font-size="19"
        font-family="Noto Sans CJK SC,sans-serif">${summary}</text>

  <!-- 品牌水印 -->
  <text x="540" y="1056" text-anchor="middle" fill="#334455" font-size="18"
        font-family="Noto Sans CJK SC,sans-serif">${watermark} · 数据来自真实行程，仅供娱乐参考</text>
</svg>
