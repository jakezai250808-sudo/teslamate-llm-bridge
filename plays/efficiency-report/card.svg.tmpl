<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080">
  <!-- 能效报告分享卡：1080x1080，深蓝底 + 超大能效数字 + 进度条 + 等级徽章。
       bar_actual_px 是实际能效对应的条形像素（0-540px 轨道），
       bar_baseline_px 固定 270px（效率比=100 对应中点）。
       grade_info.color 由等级动态注入。不含 emoji 字面（用 emoji 字段在外部展示）。 -->
  <defs>
    <linearGradient id="bggrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0d1b2a"/>
      <stop offset="0.6" stop-color="#112236"/>
      <stop offset="1" stop-color="#1a2d45"/>
    </linearGradient>
    <!-- 省电侧：绿 -->
    <linearGradient id="save-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#00e5a0"/>
      <stop offset="1" stop-color="#4dd0e1"/>
    </linearGradient>
    <!-- 耗电侧：橙→红 -->
    <linearGradient id="burn-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#ffb74d"/>
      <stop offset="1" stop-color="#ef5350"/>
    </linearGradient>
    <!-- 等级主色光晕 -->
    <filter id="glow">
      <feGaussianBlur stdDeviation="8" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- 背景 -->
  <rect width="1080" height="1080" fill="url(#bggrad)"/>

  <!-- ===== 顶栏 ===== -->
  <text x="540" y="80" text-anchor="middle"
        fill="#f0f4f8" font-size="48" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">电车有数 · 能效报告</text>
  <text x="540" y="130" text-anchor="middle"
        fill="#7a9bbf" font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">${window_label} · ${car_name} · ${drive_count} 次出行 · ${total_km} km</text>
  <line x1="80" y1="162" x2="1000" y2="162" stroke="#1e3a5a" stroke-width="2"/>

  <!-- ===== 核心数字区 ===== -->
  <!-- 实际能效大字（等级主色） -->
  <text x="540" y="220" text-anchor="middle"
        fill="#7a9bbf" font-size="28"
        font-family="Noto Sans CJK SC,sans-serif">实际能效</text>
  <text x="540" y="390" text-anchor="middle"
        fill="${grade_info.color}" font-size="200" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif" filter="url(#glow)">${actual_wh_km}</text>
  <text x="540" y="440" text-anchor="middle"
        fill="#7a9bbf" font-size="32"
        font-family="Noto Sans CJK SC,sans-serif">Wh/km（基准 ${baseline} Wh/km）</text>

  <!-- 电费叙事行 -->
  <text x="540" y="510" text-anchor="middle"
        fill="#f0f4f8" font-size="38" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">本期差价 ${period_delta_cost} 元 · 百公里 ${delta_cost_per_100km} 元</text>

  <line x1="80" y1="540" x2="1000" y2="540" stroke="#1e3a5a" stroke-width="1.5"/>

  <!-- ===== 进度条区 ===== -->
  <text x="80" y="585" fill="#7a9bbf" font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">超省</text>
  <text x="1000" y="585" text-anchor="end" fill="#7a9bbf" font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">超耗</text>
  <text x="540" y="585" text-anchor="middle" fill="#4a6a8a" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">基准线</text>

  <!-- 轨道底色 -->
  <rect x="150" y="598" width="540" height="36" rx="18" fill="#1a3050"/>

  <!-- 省电侧填充（固定从左到基准线 270px） -->
  <rect x="150" y="598" width="270" height="36" rx="18" fill="url(#save-grad)" fill-opacity="0.35"/>

  <!-- 耗电侧填充（基准线到右侧 270px） -->
  <rect x="420" y="598" width="270" height="36" rx="18" fill="url(#burn-grad)" fill-opacity="0.35"/>

  <!-- 实际位置标记（等级色 bar，宽 12px，垂直居中在轨道上方） -->
  <rect x="${bar_actual_px}" y="590" width="10" height="52" rx="5"
        fill="${grade_info.color}" filter="url(#glow)"/>

  <!-- 基准线竖虚线 -->
  <line x1="420" y1="586" x2="420" y2="650"
        stroke="#5a8aaa" stroke-width="2.5" stroke-dasharray="6,4"/>

  <!-- 轨道刻度标注：左=省 右=耗 -->
  <text x="155" y="668" fill="#7a9bbf" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">效率比 0%</text>
  <text x="410" y="668" text-anchor="middle" fill="#5a8aaa" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">100%</text>
  <text x="685" y="668" text-anchor="end" fill="#7a9bbf" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">200%</text>

  <!-- 实际效率比数值 -->
  <text x="540" y="710" text-anchor="middle"
        fill="${grade_info.color}" font-size="30" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">效率比 ${efficiency_ratio}%</text>

  <line x1="80" y1="734" x2="1000" y2="734" stroke="#1e3a5a" stroke-width="1.5"/>

  <!-- ===== 等级区 ===== -->
  <!-- 等级字母 -->
  <text x="200" y="870" text-anchor="middle"
        fill="${grade_info.color}" font-size="140" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif" filter="url(#glow)">${grade_key}</text>

  <!-- 等级名称 + 描述 -->
  <text x="620" y="800" text-anchor="middle"
        fill="#f0f4f8" font-size="52" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${grade_info.title}</text>
  <text x="620" y="848" text-anchor="middle"
        fill="#cbd5e1" font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">${grade_info.desc}</text>

  <!-- tag 徽章 -->
  <rect x="350" y="868" width="540" height="52" rx="26"
        fill="${grade_info.color}" fill-opacity="0.18"
        stroke="${grade_info.color}" stroke-width="1.5" stroke-opacity="0.7"/>
  <text x="620" y="902" text-anchor="middle"
        fill="${grade_info.color}" font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">${grade_info.tag}</text>

  <!-- ===== 底部信息条 ===== -->
  <line x1="80" y1="940" x2="1000" y2="940" stroke="#1e3a5a" stroke-width="1.5"/>
  <text x="100" y="982" fill="#7a9bbf" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${car_name} · ${window_label} · 充电 ${charge_sessions} 次 / ${total_kwh_charged} kWh</text>
  <text x="980" y="982" text-anchor="end" fill="#4a6a8a" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${watermark}</text>

  <!-- 摘要小字（用于辅助文字层） -->
  <text x="540" y="1040" text-anchor="middle"
        fill="#3a5a7a" font-size="19"
        font-family="Noto Sans CJK SC,sans-serif">${summary}</text>
</svg>
