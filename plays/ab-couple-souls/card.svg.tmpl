<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080">
  <!-- 你的车里住着两个灵魂：1080x1080，双栏对比构图，左 A 温柔灵魂 / 右 B 激进灵魂。
       占位符由引擎注入并 XML 转义；bar_* 为 compute 数值 var（轨道 380px）。
       中缝 VS 竖线，底部互动钩子 + 免责小字 + 水印。 -->
  <defs>
    <!-- 主背景：深色渐变 -->
    <linearGradient id="bg_main" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0a0f1e"/>
      <stop offset="0.5" stop-color="#0d1529"/>
      <stop offset="1" stop-color="#111827"/>
    </linearGradient>
    <!-- A 栏背景（偏蓝绿冷调，温柔感） -->
    <linearGradient id="bg_a" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0c2233"/>
      <stop offset="1" stop-color="#0d1b2a"/>
    </linearGradient>
    <!-- B 栏背景（偏橙红暖调，激进感） -->
    <linearGradient id="bg_b" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#2d1010"/>
      <stop offset="1" stop-color="#1a0d0d"/>
    </linearGradient>
    <!-- A 激进度条（蓝绿） -->
    <linearGradient id="grad_a" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#38bdf8"/>
      <stop offset="1" stop-color="#34d399"/>
    </linearGradient>
    <!-- B 激进度条（橙红） -->
    <linearGradient id="grad_b" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#f97316"/>
      <stop offset="1" stop-color="#ef4444"/>
    </linearGradient>
    <!-- 夜驾条（紫色，A/B 共用） -->
    <linearGradient id="grad_night" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#7c3aed"/>
      <stop offset="1" stop-color="#a78bfa"/>
    </linearGradient>
  </defs>

  <!-- 全底色 -->
  <rect width="1080" height="1080" fill="url(#bg_main)"/>

  <!-- ===== 品牌 / 标题区 ===== -->
  <text x="540" y="72" text-anchor="middle" fill="#f1f5f9" font-size="44" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">你的车里住着两个灵魂</text>
  <text x="540" y="114" text-anchor="middle" fill="#64748b" font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">${window_label} · 行程按驾驶风格分桶 · 分割线 ${speed_median} km/h</text>
  <line x1="60" y1="136" x2="1020" y2="136" stroke="#1e293b" stroke-width="2"/>

  <!-- ===== A 栏背景面板（左 60-510）===== -->
  <rect x="60" y="148" width="450" height="790" rx="16" fill="url(#bg_a)" stroke="#1e4a6e" stroke-width="1.5"/>

  <!-- A 栏标题 -->
  <text x="285" y="198" text-anchor="middle" fill="#38bdf8" font-size="72" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">A</text>
  <text x="285" y="238" text-anchor="middle" fill="#94a3b8" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">温柔灵魂  speed_max &lt;= 中位数</text>

  <!-- A 人格名 -->
  <text x="285" y="288" text-anchor="middle" fill="#38bdf8" font-size="36" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${a_persona.name}</text>

  <!-- A 标签徽章 -->
  <rect x="130" y="302" width="310" height="42" rx="21" fill="#0c2d45" stroke="#1e4a6e" stroke-width="1.5"/>
  <text x="285" y="330" text-anchor="middle" fill="#67e8f9" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${a_persona.tag}</text>

  <!-- A 数据行 -->
  <text x="110" y="386" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">出行次数</text>
  <text x="490" y="386" text-anchor="end" fill="#e2e8f0" font-size="24" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${a_count} 次</text>

  <text x="110" y="424" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">平均单程</text>
  <text x="490" y="424" text-anchor="end" fill="#e2e8f0" font-size="24" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${a_avg_km_r} km</text>

  <!-- A 激进度条 -->
  <text x="110" y="464" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">激进度</text>
  <rect x="110" y="472" width="380" height="18" rx="9" fill="#0f2332"/>
  <rect x="110" y="472" width="${bar_a_aggro}" height="18" rx="9" fill="url(#grad_a)"/>
  <text x="497" y="488" text-anchor="end" fill="#38bdf8" font-size="22" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${a_aggro}</text>

  <!-- A 夜驾占比条 -->
  <text x="110" y="522" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">夜驾占比</text>
  <rect x="110" y="530" width="380" height="18" rx="9" fill="#1a0f30"/>
  <rect x="110" y="530" width="${bar_a_night}" height="18" rx="9" fill="url(#grad_night)"/>
  <text x="497" y="546" text-anchor="end" fill="#a78bfa" font-size="22" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${a_night_pct}%</text>

  <!-- ===== B 栏背景面板（右 570-1020）===== -->
  <rect x="570" y="148" width="450" height="790" rx="16" fill="url(#bg_b)" stroke="#6b1a1a" stroke-width="1.5"/>

  <!-- B 栏标题 -->
  <text x="795" y="198" text-anchor="middle" fill="#f87171" font-size="72" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">B</text>
  <text x="795" y="238" text-anchor="middle" fill="#94a3b8" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">激进灵魂  speed_max &gt; 中位数</text>

  <!-- B 人格名 -->
  <text x="795" y="288" text-anchor="middle" fill="#f87171" font-size="36" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${b_persona.name}</text>

  <!-- B 标签徽章 -->
  <rect x="640" y="302" width="310" height="42" rx="21" fill="#2d0f0f" stroke="#6b1a1a" stroke-width="1.5"/>
  <text x="795" y="330" text-anchor="middle" fill="#fca5a5" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${b_persona.tag}</text>

  <!-- B 数据行 -->
  <text x="620" y="386" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">出行次数</text>
  <text x="1000" y="386" text-anchor="end" fill="#e2e8f0" font-size="24" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${b_count} 次</text>

  <text x="620" y="424" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">平均单程</text>
  <text x="1000" y="424" text-anchor="end" fill="#e2e8f0" font-size="24" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${b_avg_km_r} km</text>

  <!-- B 激进度条 -->
  <text x="620" y="464" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">激进度</text>
  <rect x="620" y="472" width="380" height="18" rx="9" fill="#2d0f0f"/>
  <rect x="620" y="472" width="${bar_b_aggro}" height="18" rx="9" fill="url(#grad_b)"/>
  <text x="1007" y="488" text-anchor="end" fill="#f87171" font-size="22" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${b_aggro}</text>

  <!-- B 夜驾占比条 -->
  <text x="620" y="522" fill="#64748b" font-size="20" font-family="Noto Sans CJK SC,sans-serif">夜驾占比</text>
  <rect x="620" y="530" width="380" height="18" rx="9" fill="#1a0f30"/>
  <rect x="620" y="530" width="${bar_b_night}" height="18" rx="9" fill="url(#grad_night)"/>
  <text x="1007" y="546" text-anchor="end" fill="#a78bfa" font-size="22" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${b_night_pct}%</text>

  <!-- ===== 中缝 VS 区 ===== -->
  <line x1="540" y1="148" x2="540" y2="938" stroke="#334155" stroke-width="2" stroke-dasharray="8,6"/>
  <!-- VS 圆形标 -->
  <circle cx="540" cy="420" r="36" fill="#1e293b" stroke="#334155" stroke-width="2"/>
  <text x="540" y="430" text-anchor="middle" fill="#f1f5f9" font-size="28" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">VS</text>

  <!-- ===== 汇总区（两栏下方，580-790px）===== -->
  <text x="540" y="625" text-anchor="middle" fill="#64748b" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">共 ${total_count} 次出行 · 速度中位数 ${speed_median} km/h 分割</text>

  <!-- 激进度对比大字 -->
  <text x="285" y="700" text-anchor="middle" fill="#38bdf8" font-size="80" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${a_aggro}</text>
  <text x="285" y="732" text-anchor="middle" fill="#94a3b8" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">激进度 /100</text>

  <text x="795" y="700" text-anchor="middle" fill="#f87171" font-size="80" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${b_aggro}</text>
  <text x="795" y="732" text-anchor="middle" fill="#94a3b8" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">激进度 /100</text>

  <!-- ===== 互动钩子区（800-920px）===== -->
  <rect x="60" y="790" width="960" height="130" rx="14" fill="#0f172a" stroke="#1e293b" stroke-width="1.5"/>
  <text x="540" y="838" text-anchor="middle" fill="#fbbf24" font-size="32" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">猜猜哪个灵魂是你  哪个是TA</text>
  <text x="540" y="878" text-anchor="middle" fill="#94a3b8" font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">评论区 @TA 来对号入座 · 一辆车两个灵魂</text>
  <text x="540" y="910" text-anchor="middle" fill="#475569" font-size="18"
        font-family="Noto Sans CJK SC,sans-serif">数据来自真实行程聚合 · AI 分析仅供娱乐参考 · 不含 GPS 定位</text>

  <!-- ===== 底部水印条 ===== -->
  <line x1="60" y1="940" x2="1020" y2="940" stroke="#1e293b" stroke-width="1.5"/>
  <text x="80" y="978" fill="#475569" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">${car_name} · ${window_label} · ${generated_at}</text>
  <text x="1000" y="978" text-anchor="end" fill="#334155" font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">${watermark}</text>
</svg>
