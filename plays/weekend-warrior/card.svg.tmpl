<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080">
  <!-- 周末战士指数分享卡：1080x1080，深海蓝黑背景 + 超大战士分视觉锤 + 对比条形图 + 徽章。
       占位符由引擎注入并 XML 转义；bar_wknd_km / bar_wkday_km 为 compute 数值 var（轨道 540px）。
       颜色：周末=橙金 #f5a623 / 工作日=冷蓝 #4a90d9 / 背景 #0d1b2a。
       不含 emoji 字面（prod 无 emoji 字形）；8 位 HEX 色拆成 fill + fill-opacity（Batik 兼容）。 -->
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0d1b2a" stop-opacity="1"/>
      <stop offset="0.6" stop-color="#111f30" stop-opacity="1"/>
      <stop offset="1" stop-color="#162438" stop-opacity="1"/>
    </linearGradient>
    <!-- 战士分渐变：橙 -> 金 -->
    <linearGradient id="scoregrad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#f5a623" stop-opacity="1"/>
      <stop offset="1" stop-color="#ffd166" stop-opacity="1"/>
    </linearGradient>
    <!-- 轨道底色 -->
    <linearGradient id="trackbg" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#1e2d3d" stop-opacity="1"/>
      <stop offset="1" stop-color="#243349" stop-opacity="1"/>
    </linearGradient>
  </defs>

  <!-- 背景 -->
  <rect width="1080" height="1080" fill="url(#bg)"/>

  <!-- ===== 顶栏 ===== -->
  <text x="540" y="76" text-anchor="middle" fill="#f1f5f9" fill-opacity="1"
        font-size="46" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">电车有数 · 周末战士</text>
  <text x="540" y="124" text-anchor="middle" fill="#94a3b8" fill-opacity="1"
        font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">${window_label} 行车数据 · 工作日 vs 周末</text>
  <line x1="120" y1="158" x2="960" y2="158" stroke="#334155" stroke-opacity="1" stroke-width="1.5"/>

  <!-- ===== 视觉锤：战士分 ===== -->
  <text x="540" y="216" text-anchor="middle" fill="#64748b" fill-opacity="1"
        font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">综合战士分</text>

  <!-- 大圆环背景 -->
  <circle cx="540" cy="340" r="140" fill="#162436" fill-opacity="1" stroke="#334155" stroke-opacity="1" stroke-width="2"/>

  <!-- 战士分数字 -->
  <text x="540" y="388" text-anchor="middle" fill="url(#scoregrad)"
        font-size="148" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${warrior_score}</text>
  <text x="540" y="420" text-anchor="middle" fill="#64748b" fill-opacity="1"
        font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">/ 100</text>

  <!-- 人格名 -->
  <text x="540" y="498" text-anchor="middle" fill="#f5a623" fill-opacity="1"
        font-size="52" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${persona.name}</text>
  <!-- 人格描述 -->
  <text x="540" y="548" text-anchor="middle" fill="#cbd5e1" fill-opacity="1"
        font-size="26"
        font-family="Noto Sans CJK SC,sans-serif">${persona.desc}</text>

  <!-- ===== 对比条形图 ===== -->
  <line x1="120" y1="580" x2="960" y2="580" stroke="#1e2d3d" stroke-opacity="1" stroke-width="1"/>

  <!-- 周末行 标题 -->
  <text x="120" y="622" fill="#f5a623" fill-opacity="1"
        font-size="28" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">周末</text>

  <!-- 周末条轨道 -->
  <rect x="230" y="604" width="540" height="28" rx="14" fill="url(#trackbg)"/>
  <!-- 周末条填充（橙金） -->
  <rect x="230" y="604" width="${bar_wknd_km}" height="28" rx="14"
        fill="#f5a623" fill-opacity="1"/>
  <!-- 周末数据标注 -->
  <text x="788" y="624" fill="#f5a623" fill-opacity="1"
        font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">${wknd_km_r} km</text>
  <text x="788" y="648" fill="#94a3b8" fill-opacity="1"
        font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">${wknd_trips} 次 · ${wknd_km_pct}%</text>

  <!-- 工作日行 标题 -->
  <text x="120" y="698" fill="#4a90d9" fill-opacity="1"
        font-size="28" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">工作日</text>

  <!-- 工作日条轨道 -->
  <rect x="230" y="680" width="540" height="28" rx="14" fill="url(#trackbg)"/>
  <!-- 工作日条填充（冷蓝） -->
  <rect x="230" y="680" width="${bar_wkday_km}" height="28" rx="14"
        fill="#4a90d9" fill-opacity="1"/>
  <!-- 工作日数据标注 -->
  <text x="788" y="700" fill="#4a90d9" fill-opacity="1"
        font-size="24"
        font-family="Noto Sans CJK SC,sans-serif">${wkday_km_r} km</text>
  <text x="788" y="724" fill="#94a3b8" fill-opacity="1"
        font-size="20"
        font-family="Noto Sans CJK SC,sans-serif">${wkday_trips} 次 · ${wkday_km_pct}%</text>

  <!-- 平均单程对比 -->
  <line x1="120" y1="754" x2="960" y2="754" stroke="#1e2d3d" stroke-opacity="1" stroke-width="1"/>
  <text x="120" y="790" fill="#64748b" fill-opacity="1"
        font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">周末单程均</text>
  <text x="310" y="790" fill="#f5a623" fill-opacity="1"
        font-size="26" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${wknd_avg_km} km</text>
  <text x="540" y="790" text-anchor="middle" fill="#475569" fill-opacity="1"
        font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">vs</text>
  <text x="620" y="790" fill="#64748b" fill-opacity="1"
        font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">工作日单程均</text>
  <text x="840" y="790" fill="#4a90d9" fill-opacity="1"
        font-size="26" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${wkday_avg_km} km</text>

  <!-- ===== 徽章 ===== -->
  <rect x="180" y="822" width="720" height="60" rx="30"
        fill="#1e2d3d" fill-opacity="1" stroke="#f5a623" stroke-opacity="0.6" stroke-width="1.5"/>
  <text x="540" y="860" text-anchor="middle" fill="#f5a623" fill-opacity="1"
        font-size="28" font-weight="bold"
        font-family="Noto Sans CJK SC,sans-serif">${persona.tag}</text>

  <!-- 一句话描述已在上方 persona.desc，此处不重复 -->

  <!-- ===== 底部信息条 ===== -->
  <line x1="120" y1="908" x2="960" y2="908" stroke="#334155" stroke-opacity="1" stroke-width="1.5"/>
  <text x="140" y="950" fill="#94a3b8" fill-opacity="1"
        font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${car_name} · ${window_label} · ${generated_at}</text>
  <text x="940" y="950" text-anchor="end" fill="#64748b" fill-opacity="1"
        font-size="22"
        font-family="Noto Sans CJK SC,sans-serif">${watermark}</text>

  <!-- 免责小字 -->
  <text x="540" y="1010" text-anchor="middle" fill="#475569" fill-opacity="1"
        font-size="18"
        font-family="Noto Sans CJK SC,sans-serif">数据来自真实行程，AI 推理仅供娱乐参考</text>
  <text x="540" y="1040" text-anchor="middle" fill="#475569" fill-opacity="1"
        font-size="18"
        font-family="Noto Sans CJK SC,sans-serif">战士分越高代表周末出行越多，不代表驾驶水平</text>
</svg>
